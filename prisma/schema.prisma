generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --------------------- Enums ---------------------

enum UserRole {
  ADMIN
  TEACHER
  STUDENT
}

enum EnrollmentRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

// --------------------- User & Profile ---------------------

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String?
  role          UserRole  @default(STUDENT)
  googleId      String?   @unique
  isActive      Boolean   @default(true)
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  profile       Profile?

  coursesOwned        Course[]             @relation("CourseTeacher")
  enrollments         Enrollment[]
  enrollmentRequests  EnrollmentRequest[]
  notifications       Notification[]
  messages            Message[]
  submissions         Submission[]
  auditLogs           AuditLog[]

  @@index([deletedAt])
}

// --------------------- Profile ---------------------

model Profile {
  id        String  @id @default(cuid())
  firstName String?
  lastName  String?
  avatarUrl String?
  userId    String  @unique
  user      User    @relation(fields: [userId], references: [id])
}

// --------------------- Courses ---------------------

model Course {
  id          String    @id @default(cuid())
  title       String    @unique
  description String?
  teacherId   String
  teacher     User      @relation("CourseTeacher", fields: [teacherId], references: [id])
  isActive    Boolean   @default(true)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  enrollments         Enrollment[]
  enrollmentRequests  EnrollmentRequest[]
  lectures            Lecture[]
  assignments         Assignment[]
  quizzes             Quiz[]
  announcements       Announcement[]
  messages            Message[]

  @@index([teacherId])
  @@index([deletedAt])
}

// --------------------- Enrollment Request ---------------------

model EnrollmentRequest {
  id        String                  @id @default(cuid())
  studentId String
  courseId  String

  student   User    @relation(fields: [studentId], references: [id])
  course    Course  @relation(fields: [courseId], references: [id], onDelete: Cascade)

  status    EnrollmentRequestStatus @default(PENDING)
  message   String?                 // Optional note from student
  note      String?                 // Optional note from teacher when rejecting

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, courseId])
  @@index([courseId, status])
  @@index([studentId])
}

// --------------------- Enrollments ---------------------

model Enrollment {
  id         String   @id @default(cuid())
  studentId  String
  courseId   String

  student    User     @relation(fields: [studentId], references: [id])
  course     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  progress   Float    @default(0)
  enrolledBy String?  // 'REQUEST', 'ADMIN', 'FREE'
  createdAt  DateTime @default(now())

  @@unique([studentId, courseId])
  @@index([studentId])
  @@index([courseId])
}

// --------------------- Learning Content ---------------------

model Lecture {
  id          String   @id @default(cuid())
  courseId    String
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  title       String   @unique
  description String?
  videoUrl    String?
  documentUrl String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([courseId])
}

model Assignment {
  id          String    @id @default(cuid())
  courseId    String
  course      Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)

  title       String
  description String?
  dueDate     DateTime?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  submissions Submission[]

  @@index([courseId])
}

model Submission {
  id           String     @id @default(cuid())
  assignmentId String
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)

  studentId    String
  student      User       @relation(fields: [studentId], references: [id])

  fileUrl      String
  submittedAt  DateTime   @default(now())

  @@unique([assignmentId, studentId])
  @@index([assignmentId])
  @@index([studentId])
}

model Quiz {
  id        String   @id @default(cuid())
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  title     String
  formUrl   String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([courseId])
}

model Announcement {
  id        String   @id @default(cuid())
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  title     String
  body      String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([courseId])
}

// --------------------- Communication ---------------------

model Message {
  id        String   @id @default(cuid())
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  senderId  String
  sender    User     @relation(fields: [senderId], references: [id])

  content   String
  createdAt DateTime @default(now())

  @@index([courseId, createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  type      String
  title     String
  body      String
  isRead    Boolean  @default(false)

  courseId  String?
  entityId  String?

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

// --------------------- Audit Logs ---------------------

model AuditLog {
  id         String   @id @default(cuid())
  adminId    String
  admin      User     @relation(fields: [adminId], references: [id])

  action     String
  resource   String?
  resourceId String?
  details    Json?

  createdAt  DateTime @default(now())

  @@index([adminId, createdAt])
}
